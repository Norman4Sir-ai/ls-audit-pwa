# Copy this file to .env and fill in your OKX DEMO API credentials.
# NEVER commit .env to version control.
# NEVER grant withdraw permissions to these keys.
# These must be OKX DEMO/paper-trading API keys, NOT live keys.

OKX_API_KEY=your_okx_demo_api_key_here
OKX_SECRET=your_okx_demo_secret_here
OKX_PASSPHRASE=your_okx_demo_passphrase_here
